<tr class="border-b border-zinc-950/5 dark:border-white/5 hover:bg-zinc-50 dark:hover:bg-white/[0.02]">
  <td class="py-2 pr-3">
    <span class="inline-flex items-center px-1.5 py-0.5 text-sm font-medium <%= event_badge_classes(event) %>">
      <%= event_label(event) %>
    </span>
  </td>
  <td class="py-2 pr-3">
    <div class="flex items-center gap-2">
      <span class="size-4 rounded-full bg-zinc-200 dark:bg-zinc-700 inline-block"><img src="<%= gravatar_url(event.recipient_email) %>" alt="" class="size-4 rounded-full"></span>
      <span><%= event.recipient_email %></span>
    </div>
  </td>
  <td class="py-2 pr-3">
    <% if event.message %>
      <% subject = event.message.subject.presence || "[no subject]" %>
      <%= link_to truncate(subject, length: 60), source_message_path(event.message.source, event.message), class: "hover:underline" %>
    <% else %>
      <span class="text-zinc-400 dark:text-zinc-500">[no subject]</span>
    <% end %>
  </td>
  <td class="py-2 text-right text-zinc-500 dark:text-zinc-400 whitespace-nowrap tabular-nums">
    <%= local_time(event.event_at, format: :event_timestamp) %>
  </td>
</tr>
