<%= render layout: "sessy/sources/layout", locals: { source: @source, active: :activity } do %>
  <div class="mb-5 space-y-3">
    <%= form_with url: source_events_path(@source), method: :get, id: "events-filter-form", class: "space-y-3", data: { controller: "debounced-submit" } do |f| %>
      <div class="flex items-center gap-3">
        <%= search_field_tag :query, params[:query],
            placeholder: "Search by email or subject...",
            class: "w-full max-w-sm border border-zinc-950/10 dark:border-white/10 bg-transparent px-2.5 py-1.5 text-sm placeholder:text-zinc-400 dark:placeholder:text-zinc-500 focus:outline-none focus:ring-1 focus:ring-zinc-950/20 dark:focus:ring-white/20",
            "aria-label": "Search events",
            data: { action: "input->debounced-submit#submit search->debounced-submit#submit" } %>

        <div class="flex items-center gap-2 ml-auto">
          <%= link_to "Export", source_events_path(@source, format: :csv, **request.query_parameters), class: "px-2.5 py-1.5 text-sm border border-zinc-950/10 dark:border-white/10 hover:bg-zinc-50 dark:hover:bg-white/5 whitespace-nowrap" %>

          <div class="relative">
            <%= select_tag :date_range,
                options_for_select(Sessy::Event.date_range_presets.map { |k, v| [v, k] }, params[:date_range] || "last_30_days"),
                class: "appearance-none border border-zinc-950/10 dark:border-white/10 bg-transparent pl-2.5 pr-7 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-zinc-950/20 dark:focus:ring-white/20 cursor-pointer",
                onchange: "this.form.requestSubmit()" %>
            <div class="pointer-events-none absolute inset-y-0 right-2 flex items-center text-zinc-400 dark:text-zinc-500">
              <svg class="size-3.5" viewBox="0 0 16 16" fill="currentColor"><path fill-rule="evenodd" d="M4.22 6.22a.75.75 0 0 1 1.06 0L8 8.94l2.72-2.72a.75.75 0 1 1 1.06 1.06l-3.25 3.25a.75.75 0 0 1-1.06 0L4.22 7.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"/></svg>
            </div>
          </div>
        </div>
      </div>

      <div class="flex flex-wrap items-center gap-1.5">
        <% active_types = Array(params[:event_types]).reject(&:blank?) %>
        <% Sessy::EventsHelper::EVENT_TYPE_FILTERS.each do |type, label| %>
          <% count = @filter_counts.dig(:event_types, type) || 0 %>
          <% is_active = active_types.include?(type) %>
          <label class="cursor-pointer">
            <input type="checkbox" name="event_types[]" value="<%= type %>"
              <%= "checked" if is_active %>
              class="peer sr-only"
              onchange="this.form.requestSubmit()">
            <span class="inline-flex items-center gap-1 px-1.5 py-0.5 text-sm border
              border-zinc-950/10 dark:border-white/10 text-zinc-400 dark:text-zinc-500 hover:text-zinc-600 dark:hover:text-zinc-300
              peer-checked:hidden">
              <%= label %><span class="tabular-nums opacity-60"><%= number_with_delimiter(count) %></span>
            </span>
            <span class="hidden items-center gap-1 px-1.5 py-0.5 text-sm border
              <%= event_filter_chip_classes(type) %>
              peer-checked:inline-flex">
              <%= label %><span class="tabular-nums opacity-60"><%= number_with_delimiter(count) %></span>
            </span>
          </label>
        <% end %>

        <% if active_types.any? %>
          <%= link_to "Clear", source_events_path(@source, query: params[:query].presence), class: "text-sm text-zinc-400 hover:text-zinc-600 dark:hover:text-zinc-300" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <% if @events.any? %>
    <div class="-mx-4 -my-2 overflow-x-auto whitespace-nowrap sm:-mx-6">
      <div class="inline-block min-w-full px-4 py-2 align-middle sm:px-6">
        <table class="min-w-full text-sm table-fixed">
          <colgroup>
            <col class="w-28">
            <col class="w-64">
            <col>
            <col class="w-40">
          </colgroup>
          <thead>
            <tr class="border-b border-zinc-950/10 dark:border-white/10">
              <th class="py-2 pr-3 text-left font-medium whitespace-nowrap text-zinc-500 dark:text-zinc-400">Event</th>
              <th class="py-2 pr-3 text-left font-medium whitespace-nowrap text-zinc-500 dark:text-zinc-400">Recipient</th>
              <th class="py-2 pr-3 text-left font-medium whitespace-nowrap text-zinc-500 dark:text-zinc-400">Subject</th>
              <th class="py-2 text-right font-medium whitespace-nowrap text-zinc-500 dark:text-zinc-400">Time</th>
            </tr>
          </thead>
          <tbody>
            <%= render partial: "event", collection: @events %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="mt-4">
      <%== @pagy.series_nav %>
    </div>
  <% else %>
    <div class="text-center py-16">
      <p class="text-sm text-zinc-500 dark:text-zinc-400">No events yet.</p>
    </div>
  <% end %>
<% end %>
