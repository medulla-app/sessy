<div class="mx-auto max-w-6xl px-4 py-6 sm:px-6">
  <div class="mb-4">
    <%= link_to source_events_path(@source), class: "text-sm text-zinc-400 hover:text-zinc-900 dark:text-zinc-500 dark:hover:text-zinc-100" do %>
      &larr; Back to Activity
    <% end %>
    <h1 class="text-lg font-semibold mt-2">Message details</h1>
  </div>

  <dl class="text-sm">
    <div class="py-2.5 border-b border-zinc-950/5 dark:border-white/5 flex gap-4">
      <dt class="w-28 shrink-0 text-zinc-500 dark:text-zinc-400">Subject</dt>
      <dd class="font-medium"><%= @message.subject || "[no subject]" %></dd>
    </div>

    <div class="py-2.5 border-b border-zinc-950/5 dark:border-white/5 flex gap-4">
      <dt class="w-28 shrink-0 text-zinc-500 dark:text-zinc-400">From</dt>
      <dd><%= @message.source_email %></dd>
    </div>

    <div class="py-2.5 border-b border-zinc-950/5 dark:border-white/5 flex gap-4">
      <dt class="w-28 shrink-0 text-zinc-500 dark:text-zinc-400">To</dt>
      <dd>
        <% @message.destination_emails.each do |email| %>
          <div><%= email %></div>
        <% end %>
      </dd>
    </div>

    <div class="py-2.5 border-b border-zinc-950/5 dark:border-white/5 flex gap-4">
      <dt class="w-28 shrink-0 text-zinc-500 dark:text-zinc-400">Sent at</dt>
      <dd class="tabular-nums"><%= @message.sent_at ? local_time(@message.sent_at, format: :message_timestamp) : "N/A" %></dd>
    </div>

    <% if @message.tags.present? %>
      <div class="py-2.5 border-b border-zinc-950/5 dark:border-white/5 flex gap-4">
        <dt class="w-28 shrink-0 text-zinc-500 dark:text-zinc-400">Tags</dt>
        <dd class="flex flex-wrap gap-1">
          <% @message.tags.each do |key, value| %>
            <span class="inline-flex items-center bg-zinc-100 dark:bg-white/5 px-1.5 py-0.5 text-sm font-mono"><%= key %>=<%= Array(value).join(", ") %></span>
          <% end %>
        </dd>
      </div>
    <% end %>

    <div class="py-2.5 border-b border-zinc-950/5 dark:border-white/5 flex gap-4">
      <dt class="w-28 shrink-0 text-zinc-500 dark:text-zinc-400">SES ID</dt>
      <dd class="font-mono break-all text-zinc-600 dark:text-zinc-300"><%= @message.ses_message_id %></dd>
    </div>

    <div class="py-2.5 border-b border-zinc-950/5 dark:border-white/5">
      <dt class="text-zinc-500 dark:text-zinc-400 mb-2">Events (<%= @message.events_count %>)</dt>
      <dd class="space-y-1">
        <% @message.events.reverse_chronologically.each do |event| %>
          <div class="flex items-center justify-between py-1.5">
            <div class="flex items-center gap-2.5">
              <span class="inline-flex items-center px-1.5 py-0.5 text-sm font-medium <%= event_badge_classes(event) %>">
                <%= event_label(event) %>
              </span>
              <div class="flex items-center gap-1.5">
                <span class="size-4 rounded-full bg-zinc-200 dark:bg-zinc-700 inline-block"><img src="<%= gravatar_url(event.recipient_email) %>" alt="" class="size-4 rounded-full"></span>
                <span><%= event.recipient_email %></span>
              </div>
            </div>
            <span class="text-zinc-500 dark:text-zinc-400 tabular-nums"><%= local_time(event.event_at, format: :event_timestamp) %></span>
          </div>
        <% end %>
      </dd>
    </div>

    <div class="py-2.5">
      <details>
        <summary class="text-zinc-500 dark:text-zinc-400 cursor-pointer hover:text-zinc-700 dark:hover:text-zinc-200">Mail metadata</summary>
        <pre class="mt-2 text-sm p-3 bg-zinc-50 dark:bg-white/5 overflow-x-auto font-mono text-zinc-700 dark:text-zinc-300"><%= JSON.pretty_generate(@message.mail_metadata) %></pre>
      </details>
    </div>
  </dl>
</div>
